# ----------------------------------------
# 🔐 Environment Variables & Secrets
# ----------------------------------------
# Arquivos de ambiente (NUNCA commitar)
# Ignora apenas .env específicos, NÃO .env.example
.env
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Permitir .env.example em qualquer pasta
!**/.env.example

# Arquivos de configuração sensíveis
config.local.*
secrets.*
*.key
*.pem
*.p12
*.pfx

