# ===========================================
# Backend Environment Variables
# ===========================================
# Copie este arquivo para .env e ajuste conforme necessário
# cp .env.example .env

# Database Configuration
# Para desenvolvimento local (backend rodando no host)
DATABASE_URL=postgres://movix:movix123@localhost:5432/movix?sslmode=disable

# Para backend rodando em Docker (use 'postgres' como host)
# DATABASE_URL=postgres://movix:movix123@postgres:5432/movix?sslmode=disable

# JWT Configuration
# IMPORTANTE: Mude este secret em produção!
JWT_SECRET=your-secret-key-change-in-production-use-a-strong-random-string

# Server Configuration
PORT=8080

# Environment (development, staging, production)
# O seed só roda em 'development'
ENVIRONMENT=development

